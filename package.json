{
  "name": "banal",
  "private": true,
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "prepare": "husky && node scripts/patch-husky-runner.mjs",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "test:api": "nx run api:test",
    "test:web": "nx run web:test",
    "test:contracts": "nx run shared-contracts:test",
    "test:api:e2e": "nx run api:test:e2e",
    "test:web:e2e": "nx run web-e2e:e2e",
    "test:web:smoke": "nx run web:test:smoke",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "validate:tests-first": "node scripts/validate-tests-first.mjs --ci",
    "test:scripts": "node --test scripts/*.spec.mjs",
    "dev:api": "nx run api:build && node scripts/dev-api.mjs",
    "dev:web": "node scripts/dev-web.mjs",
    "openapi:export": "node scripts/export-openapi.mjs",
    "openapi:generate": "node scripts/generate-openapi-client.mjs",
    "openapi:check": "node scripts/check-openapi-drift.mjs",
    "ci": "npm run validate:tests-first && npm run format:check && nx run-many -t lint && nx run-many -t typecheck && nx run-many -t build && nx run-many -t test && npm run test:scripts && npm run openapi:check",
    "ci:full": "npm run ci && npm run test:api:e2e && npm run test:web:e2e"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}": "prettier --write",
    "*.{js,mjs,cjs,ts,tsx}": "eslint --fix --max-warnings=0 --no-warn-ignored"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "~23.1",
    "@nx/vite": "~23.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "nx": "~23.1",
    "prettier": "^3.9.6",
    "tree-kill": "^1.2.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}

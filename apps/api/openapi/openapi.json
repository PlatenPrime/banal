    "/api/v1/auth/register": {
      "post": {
        "operationId": "AuthController_register_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthUserResponseDto"
                }
              }
            }
          },
          "403": {
            "description": "Registration disabled"
          }
        },
        "summary": "Register a platform user (when AUTH_REGISTRATION_ENABLED)",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "operationId": "AuthController_login_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthUserResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        },
        "summary": "Login with username and password",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh_v1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthUserResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid refresh cookie"
          }
        },
        "summary": "Rotate refresh token and issue new cookies",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "operationId": "AuthController_logout_v1",
        "parameters": [],
        "responses": {
          "204": {
            "description": "Cookies cleared"
          }
        },
        "summary": "Revoke refresh session and clear auth cookies",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "operationId": "AuthController_me_v1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthUserResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid access cookie"
          }
        },
        "security": [
          {
            "access_token": []
          }
        ],
        "summary": "Current authenticated user",
        "tags": [
          "auth"
        ]
      }
    }
  },
  "info": {
    "title": "Banal API",
    "description": "Platform API (auth via httpOnly cookies)",
    "version": "1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access_token"
      }
    },
    "schemas": {
      "ExampleResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "name": {
            "type": "string",
            "example": "Alpha",
            "minLength": 1,
            "maxLength": 200
          },
          "description": {
            "type": "object",
            "nullable": true,
            "example": "Optional description",
            "maxLength": 2000
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-07-21T10:00:00.000Z"
          }
        },
        "required": [
          "id",
          "name",
          "createdAt"
        ]
      },
      "ExampleListResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExampleResponseDto"
            }
          },
          "total": {
            "type": "number",
            "example": 1,
            "minimum": 0
          }
        },
        "required": [
          "items",
          "total"
        ]
      },
      "CreateExampleDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Alpha",
            "minLength": 1,
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "example": "Optional description",
            "maxLength": 2000
          }
        },
        "required": [
          "name"
        ]
      },
      "RegisterRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "alice@example.com"
          },
          "username": {
            "type": "string",
            "example": "alice",
            "minLength": 3,
            "maxLength": 32
          },
          "password": {
            "type": "string",
            "example": "correct-horse",
            "minLength": 8,
            "maxLength": 128
          }
        },
        "required": [
          "email",
          "username",
          "password"
        ]
      },
      "AuthUserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "email": {
            "type": "string",
            "example": "alice@example.com"
          },
          "username": {
            "type": "string",
            "example": "alice"
          }
        },
        "required": [
          "id",
          "email",
          "username"
        ]
      },
      "LoginRequestDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "alice",
            "minLength": 3,
            "maxLength": 32
          },
          "password": {
            "type": "string",
            "example": "correct-horse",
            "minLength": 8,
            "maxLength": 128
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "HealthCheckResultDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "error"
            ]
          },
          "detail": {
            "type": "string",
            "example": "connection refused"
          }
        },
        "required": [
          "status"
        ]
      }
    }
  }
}

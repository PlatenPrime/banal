NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/app_foundation_dev

# Browser origin for Nest CORS (must match the Vite web origin). See docs/LOCAL_SETUP.md#web--api-local.
WEB_ORIGIN=http://localhost:3000
# Optional Vercel preview allowlist (staging API). See docs/ops/environments.md.
# WEB_ORIGIN_PREVIEW_REGEX=^https://.*\.vercel\.app$
# WEB_ORIGIN_PREVIEW_LIST=https://my-app-git-feature.vercel.app

# JWT secrets — local placeholders only (≥32 chars, must differ). Never commit real values.
JWT_ACCESS_SECRET=local-dev-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=local-dev-refresh-secret-min-32-chars!

# Cookies (leave COOKIE_DOMAIN empty for host-only cookies on localhost).
# COOKIE_DOMAIN=.example.com
AUTH_COOKIE_SAMESITE=lax
AUTH_REGISTRATION_ENABLED=false

# Bootstrap first admin (nx run api:bootstrap-admin). Do not commit real values.
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=change-me-min-8-chars

# Railway staging/prod must set TRUST_PROXY=1. Local: leave false/0.
TRUST_PROXY=0

# OTel (wiring in T20). When OTEL_ENABLED=true, set OTEL_EXPORTER_OTLP_ENDPOINT.
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com

# Copy to `.env` for local overrides (optional; gitignored).
# Dev/build/test defaults live in `.env.development`, `.env.production`, and `.env.test`.
# Deploy/CI can override via the process environment (VITE_* vars).
# Absolute Nest API base (SSR + browser). Pair with apps/api WEB_ORIGIN=http://localhost:3000.
# Do not use a Vite proxy — see docs/LOCAL_SETUP.md#web--api-local.
VITE_API_URL=http://localhost:4000
